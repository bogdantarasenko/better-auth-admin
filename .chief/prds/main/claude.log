"^2.1.9\",\n    85→    \"react-responsive\": \"^10.0.1\",\n    86→    \"recharts\": \"^2.15.4\",\n    87→    \"sharp\": \"^0.33.5\",\n    88→    \"sonner\": \"^1.7.4\",\n    89→    \"sort-by\": \"^1.2.0\",\n    90→    \"tailwind-merge\": \"^3.5.0\",\n    91→    \"tailwindcss\": \"^4.2.2\",\n    92→    \"tailwindcss-animate\": \"^1.0.7\",\n    93→    \"typescript\": \"5.7.2\",\n    94→    \"uuid\": \"^11.1.0\",\n    95→    \"vaul\": \"^1.1.2\",\n    96→    \"zod\": \"^4.3.6\",\n    97→    \"zustand\": \"^5.0.12\"\n    98→  },\n    99→  \"devDependencies\": {\n   100→    \"@faker-js/faker\": \"^9.9.0\",\n   101→    \"@types/better-sqlite3\": \"^7.6.13\",\n   102→    \"@types/node\": \"22.10.2\",\n   103→    \"@types/react\": \"19.2.14\",\n   104→    \"@types/react-dom\": \"19.2.3\",\n   105→    \"@types/sort-by\": \"^1.2.3\",\n   106→    \"@types/uuid\": \"^10.0.0\",\n   107→    \"drizzle-kit\": \"^0.31.10\",\n   108→    \"husky\": \"^9.1.7\",\n   109→    \"lint-staged\": \"^15.5.2\",\n   110→    \"oxfmt\": \"^0.42.0\",\n   111→    \"oxlint\": \"^1.57.0\",\n   112→    \"tw-animate-css\": \"^1.4.0\"\n   113→  },\n   114→  \"overrides\": {\n   115→    \"@types/react\": \"19.2.14\",\n   116→    \"@types/react-dom\": \"19.2.3\"\n   117→  },\n   118→  \"lint-staged\": {\n   119→    \"!(scripts)/**/*.{js,jsx,tsx,ts,css,less,scss,sass}\": [\n   120→      \"oxfmt --write\"\n   121→    ]\n   122→  }\n   123→}\n   124→"}]},"parent_tool_use_id":"toolu_01MCDjZVQ9znYCyrVzkSMb8F","session_id":"5ecfe1e9-6f52-4d05-b142-586fa1064d01","uuid":"c3281ab2-45c1-4799-9aac-6123cc69349b"}
