ault(sql`(cast(unixepoch('subsecond') * 1000 as integer))`)\n    91→      .$onUpdate(() => /* @__PURE__ */ new Date())\n    92→      .notNull(),\n    93→  },\n    94→  (table) => [index(\"verification_identifier_idx\").on(table.identifier)],\n    95→);\n    96→\n    97→export const organization = sqliteTable(\n    98→  \"organization\",\n    99→  {\n   100→    id: text(\"id\").primaryKey(),\n   101→    name: text(\"name\").notNull(),\n   102→    slug: text(\"slug\").notNull().unique(),\n   103→    logo: text(\"logo\"),\n   104→    createdAt: integer(\"created_at\", { mode: \"timestamp_ms\" }).notNull(),\n   105→    metadata: text(\"metadata\"),\n   106→  },\n   107→  (table) => [uniqueIndex(\"organization_slug_uidx\").on(table.slug)],\n   108→);\n   109→\n   110→export const member = sqliteTable(\n   111→  \"member\",\n   112→  {\n   113→    id: text(\"id\").primaryKey(),\n   114→    organizationId: text(\"organization_id\")\n   115→      .notNull()\n   116→      .references(() => organization.id, { onDelete: \"cascade\" }),\n   117→    userId: text(\"user_id\")\n   118→      .notNull()\n   119→      .references(() => user.id, { onDelete: \"cascade\" }),\n   120→    role: text(\"role\").default(\"member\").notNull(),\n   121→    createdAt: integer(\"created_at\", { mode: \"timestamp_ms\" }).notNull(),\n   122→  },\n   123→  (table) => [\n   124→    index(\"member_organizationId_idx\").on(table.organizationId),\n   125→    index(\"member_userId_idx\").on(table.userId),\n   126→  ],\n   127→);\n   128→\n   129→export const invitation = sqliteTable(\n   130→  \"invitation\",\n   131→  {\n   132→    id: text(\"id\").primaryKey(),\n   133→    organizationId: text(\"organization_id\")\n   134→      .notNull()\n   135→      .references(() => organization.id, { onDelete: \"cascade\" }),\n   136→    email: text(\"email\").notNull(),\n   137→    role: text(\"role\"),\n   138→    status: text(\"status\").default(\"pending\").notNull(),\n   139→    expiresAt: integer(\"expires_