{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XAK7HiJbc1QsQXv276rQV8","type":"tool_result","content":"     1→import { Icons } from '@/components/icons';\n     2→\n     3→export interface PermissionCheck {\n     4→  permission?: string;\n     5→  plan?: string;\n     6→  feature?: string;\n     7→  role?: string;\n     8→  requireOrg?: boolean;\n     9→}\n    10→\n    11→export interface NavItem {\n    12→  title: string;\n    13→  url: string;\n    14→  disabled?: boolean;\n    15→  external?: boolean;\n    16→  shortcut?: [string, string];\n    17→  icon?: keyof typeof Icons;\n    18→  label?: string;\n    19→  description?: string;\n    20→  isActive?: boolean;\n    21→  items?: NavItem[];\n    22→  access?: PermissionCheck;\n    23→}\n    24→\n    25→export interface NavGroup {\n    26→  label: string;\n    27→  items: NavItem[];\n    28→}\n    29→\n    30→export interface NavItemWithChildren extends NavItem {\n    31→  items: NavItemWithChildren[];\n    32→}\n    33→\n    34→export interface NavItemWithOptionalChildren extends NavItem {\n    35→  items?: NavItemWithChildren[];\n    36→}\n    37→\n    38→export interface FooterItem {\n    39→  title: string;\n    40→  items: {\n    41→    title: string;\n    42→    href: string;\n    43→    external?: boolean;\n    44→  }[];\n    45→}\n    46→\n    47→export type MainNavItem = NavItemWithOptionalChildren;\n    48→\n    49→export type SidebarNavItem = NavItemWithChildren;\n    50→"}]},"parent_tool_use_id":null,"session_id":"ce8911dc-a828-4e89-bfb5-264eebf8fb2a","uuid":"fb5a7e90-b0d1-4e69-9874-67356913ad6f","tool_use_result":{"type":"text","file":{"filePath":"/Users/bogdantarasenko/Desktop/hackinterview-tool/next-shadcn-dashboard-starter/src/types/index.ts","content":"import { Icons } from '@/components/icons';\n\nexport interface PermissionCheck {\n  permission?: string;\n  plan?: string;\n  feature?: string;\n  role?: string;\n  requireOrg?: boolean;\n}\n\nexport interface NavItem {\n  title: string;\n  url: string;\n  disabled?: boolean;\n  external?: boolean;\n  shortcut?: [string, string];\n  icon?: keyof typeof Icons;\n  label?: string;\n  description?: string;\n  isActive?: boolean;\n  items?: NavItem[];\n  access?: PermissionCheck;\n}\n\nexport interface NavGroup {\n  label: string;\n  items: NavItem[];\n}\n\nexport interface NavItemWithChildren extends NavItem {\n  items: NavItemWithChildren[];\n}\n\nexport interface NavItemWithOptionalChildren extends NavItem {\n  items?: NavItemWithChildren[];\n}\n\nexport interface FooterItem {\n  title: string;\n  items: {\n    title: string;\n    href: string;\n    external?: boolean;\n  }[];\n}\n\nexport type MainNavItem = NavItemWithOptionalChildren;\n\nexport type SidebarNavItem = NavItemWithChildren;\n","numLines":50,"startLine":1,"totalLines":50}}}
