{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B4RSgskKCMEXGtoZA3y2V3","type":"tool_result","content":"     1→'use client';\n     2→\n     3→import PageContainer from '@/components/layout/page-container';\n     4→import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';\n     5→import { authClient } from '@/lib/auth-client';\n     6→import { Icons } from '@/components/icons';\n     7→import { Alert, AlertDescription } from '@/components/ui/alert';\n     8→import Link from 'next/link';\n     9→\n    10→export default function ExclusivePage() {\n    11→  const { data: activeOrg, isPending } = authClient.useActiveOrganization();\n    12→\n    13→  // Plan check placeholder — actual subscription check will use stripe plugin (US-008)\n    14→  // For now, show exclusive content if user has an active organization\n    15→  const hasPro = !!activeOrg;\n    16→\n    17→  return (\n    18→    <PageContainer isLoading={isPending}>\n    19→      {!hasPro ? (\n    20→        <div className='flex h-full items-center justify-center'>\n    21→          <Alert>\n    22→            <Icons.lock className='h-5 w-5 text-yellow-600' />\n    23→            <AlertDescription>\n    24→              <div className='mb-1 text-lg font-semibold'>Pro Plan Required</div>\n    25→              <div className='text-muted-foreground'>\n    26→                This page is only available to organizations on the{' '}\n    27→                <span className='font-semibold'>Pro</span> plan.\n    28→                <br />\n    29→                Upgrade your subscription in&nbsp;\n    30→                <Link className='underline' href='/dashboard/billing'>\n    31→                  Billing &amp; Plans\n    32→                </Link>\n    33→                .\n    34→              </div>\n    35→            </AlertDescription>\n    36→          </Alert>\n    37→        </div>\n    38→      ) : (\n    39→        <div className='space-y-6'>\n    40→          <div>\n    41→            <h1 className='flex items-center gap-2 text-3xl font-bold tracking-tight'>\n    42→              <Icons.badgeCheck className='h-7 w-7 text-green-600' />\n    43→              Exclusive Area\n    44→            </h1>\n    45→            <p className='text-muted-foreground'>\n    46→              Welcome, <span className='font-semibold'>{activeOrg.name}</span>! This page\n    47→              contains exclusive features for Pro plan organizations.\n    48→            </p>\n    49→          </div>\n    50→          <Card>\n    51→            <CardHeader>\n    52→              <CardTitle>Thank You for Checking Out the Exclusive Page</CardTitle>\n    53→              <CardDescription>\n    54→                This means you belong to an organization subscribed to the Pro plan.\n    55→              </CardDescription>\n    56→            </CardHeader>\n    57→            <CardContent>\n    58→              <div className='text-lg'>Have a wonderful day!</div>\n    59→            </CardContent>\n    60→          </Card>\n    61→        </div>\n    62→      )}\n    63→    </PageContainer>\n    64→  );\n    65→}\n    66→"}]},"parent_tool_use_id":"toolu_01MCDjZVQ9znYCyrVzkSMb8F","session_id":"5ecfe1e9-6f52-4d05-b142-586fa1064d01","uuid":"9b601df3-a893-4567-8a8a-b48c84fd1559"}
