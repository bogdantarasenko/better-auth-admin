{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AGEkPWCq7f3K5ZijRs5oe4","type":"tool_result","content":"     1→'use client';\n     2→\n     3→import { cn } from '@/lib/utils';\n     4→import React, { useState } from 'react';\n     5→\n     6→/**\n     7→ * InteractiveGridPattern is a component that renders a grid pattern with interactive squares.\n     8→ *\n     9→ * @param width - The width of each square.\n    10→ * @param height - The height of each square.\n    11→ * @param squares - The number of squares in the grid. The first element is the number of horizontal squares, and the second element is the number of vertical squares.\n    12→ * @param className - The class name of the grid.\n    13→ * @param squaresClassName - The class name of the squares.\n    14→ */\n    15→interface InteractiveGridPatternProps extends React.SVGProps<SVGSVGElement> {\n    16→  width?: number;\n    17→  height?: number;\n    18→  squares?: [number, number]; // [horizontal, vertical]\n    19→  className?: string;\n    20→  squaresClassName?: string;\n    21→}\n    22→\n    23→/**\n    24→ * The InteractiveGridPattern component.\n    25→ *\n    26→ * @see InteractiveGridPatternProps for the props interface.\n    27→ * @returns A React component.\n    28→ */\n    29→export function InteractiveGridPattern({\n    30→  width = 40,\n    31→  height = 40,\n    32→  squares = [24, 24],\n    33→  className,\n    34→  squaresClassName,\n    35→  ...props\n    36→}: InteractiveGridPatternProps) {\n    37→  const [horizontal, vertical] = squares;\n    38→  const [hoveredSquare, setHoveredSquare] = useState<number | null>(null);\n    39→\n    40→  return (\n    41→    <svg\n    42→      width={width * horizontal}\n    43→      height={height * vertical}\n    44→      className={cn('absolute inset-0 h-full w-full border border-gray-400/30', className)}\n    45→      {...props}\n    46→    >\n    47→      {Array.from({ length: horizontal * vertical }).map((_, index) => {\n    48→        const x = (index % horizontal) * width;\n    49→        const y = Math.floor(index / horizontal) * height;\n    50→        return (\n    51→          <rect\n    52→            key={index}\n    53→            x={x}\n    54→            y={y}\n    55→            width={width}\n    56→            height={height}\n    57→            className={cn(\n    58→              'stroke-gray-400/30 transition-all duration-100 ease-in-out [&:not(:hover)]:duration-1000',\n    59→              hoveredSquare === index ? 'fill-gray-300/30' : 'fill-transparent',\n    60→              squaresClassName\n    61→            )}\n    62→            onMouseEnter={() => setHoveredSquare(index)}\n    63→            onMouseLeave={() => setHoveredSquare(null)}\n    64→          />\n    65→        );\n    66→      })}\n    67→    </svg>\n    68→  );\n    69→}\n    70→"}]},"parent_tool_use_id":"toolu_01AGzBvQkycU8KLSciqMzzAB","session_id":"a376da1e-a7ce-441b-9f5b-3e1afd8c1168","uuid":"38953e72-d2fe-420b-9c40-7a6e5ca0d03b"}
