mponentAnnotation: {\n    54→        enabled: true\n    55→      },\n    56→      treeshake: {\n    57→        removeDebugLogging: true\n    58→      }\n    59→    },\n    60→\n    61→    // Disable source map upload when org/project are not configured\n    62→    sourcemaps: {\n    63→      disable: !process.env.NEXT_PUBLIC_SENTRY_ORG || !process.env.NEXT_PUBLIC_SENTRY_PROJECT\n    64→    }\n    65→  });\n    66→}\n    67→\n    68→const nextConfig = configWithPlugins;\n    69→export default nextConfig;\n    70→"}]},"parent_tool_use_id":null,"session_id":"ce8911dc-a828-4e89-bfb5-264eebf8fb2a","uuid":"4fb6dde9-55bc-4070-93a5-338451f230c9","tool_use_result":{"type":"text","file":{"filePath":"/Users/bogdantarasenko/Desktop/hackinterview-tool/next-shadcn-dashboard-starter/next.config.ts","content":"import type { NextConfig } from 'next';\nimport { withSentryConfig } from '@sentry/nextjs';\n\n// Define the base Next.js configuration\nconst baseConfig: NextConfig = {\n  output: process.env.BUILD_STANDALONE === 'true' ? 'standalone' : undefined,\n  images: {\n    remotePatterns: [\n      {\n        protocol: 'https',\n        hostname: 'api.slingacademy.com',\n        port: ''\n      },\n      {\n        protocol: 'https',\n        hostname: 'img.clerk.com',\n        port: ''\n      },\n      {\n        protocol: 'https',\n        hostname: 'clerk.com',\n        port: ''\n      }\n    ]\n  },\n  transpilePackages: ['geist'],\n  compiler: {\n    removeConsole: process.env.NODE_ENV === 'production'\n  }\n};\n\nlet configWithPlugins = baseConfig;\n\n// Conditionally enable Sentry configuration\nif (!process.env.NEXT_PUBLIC_SENTRY_DISABLED) {\n  configWithPlugins = withSentryConfig(configWithPlugins, {\n    org: process.env.NEXT_PUBLIC_SENTRY_ORG,\n    project: process.env.NEXT_PUBLIC_SENTRY_PROJECT,\n    // Only print logs for uploading source maps in CI\n    silent: !process.env.CI,\n\n    // Upload a larger set of source maps for prettier stack traces (increases build time)