{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CBcPnaKy4Sx9mmgDeCa9Uz","type":"tool_result","content":"     1→'use client';\n     2→import { Collapsible, CollapsibleContent, CollapsibleTrigger } from '@/components/ui/collapsible';\n     3→import {\n     4→  DropdownMenu,\n     5→  DropdownMenuContent,\n     6→  DropdownMenuGroup,\n     7→  DropdownMenuItem,\n     8→  DropdownMenuLabel,\n     9→  DropdownMenuSeparator,\n    10→  DropdownMenuTrigger\n    11→} from '@/components/ui/dropdown-menu';\n    12→import {\n    13→  Sidebar,\n    14→  SidebarContent,\n    15→  SidebarFooter,\n    16→  SidebarGroup,\n    17→  SidebarGroupLabel,\n    18→  SidebarHeader,\n    19→  SidebarMenu,\n    20→  SidebarMenuButton,\n    21→  SidebarMenuItem,\n    22→  SidebarMenuSub,\n    23→  SidebarMenuSubButton,\n    24→  SidebarMenuSubItem,\n    25→  SidebarRail\n    26→} from '@/components/ui/sidebar';\n    27→import { UserAvatarProfile } from '@/components/user-avatar-profile';\n    28→import { navGroups } from '@/config/nav-config';\n    29→import { useMediaQuery } from '@/hooks/use-media-query';\n    30→import { useOrganization, useUser } from '@clerk/nextjs';\n    31→import { useFilteredNavGroups } from '@/hooks/use-nav';\n    32→import { SignOutButton } from '@clerk/nextjs';\n    33→import Link from 'next/link';\n    34→import { usePathname, useRouter } from 'next/navigation';\n    35→import * as React from 'react';\n    36→import { Icons } from '../icons';\n    37→import { OrgSwitcher } from '../org-switcher';\n    38→\n    39→export default function AppSidebar() {\n    40→  const pathname = usePathname();\n    41→  const { isOpen } = useMediaQuery();\n    42→  const { user } = useUser();\n    43→  const { organization } = useOrganization();\n    44→  const router = useRouter();\n    45→  const filteredGroups = useFilteredNavGroups(navGroups);\n    46→\n    47→  React.useEffect(() => {\n    48→    // Side effects based on sidebar state changes\n    49→  }, [isOpen]);\n    50→\n    51→  return (\n    52→    <Sidebar collapsible='icon'>\n    53→      <SidebarHeader className='group-data-[collapsible=icon]:pt-4'>\n    54→        <OrgSwitcher />\n    55→      </SidebarHeader>\n    56→      <SidebarContent className='overflow-x-hidden'>\n    57→        {filteredGroups.map((group) => (\n    58→          <SidebarGroup key={group.label || 'ungrouped'} className='py-0'>\n    59→            {group.label && <SidebarGroupLabel>{group.label}</SidebarGroupLabel>}\n    60→            <SidebarMenu>\n    61→              {group.items.map((item) => {\n    62→                const Icon = item.icon ? Icons[item.icon] : Icons.logo;\n    63→                return item?.items && item?.items?.length > 0 ? (\n    64→                  <Collapsible\n    65→                    key={item.title}\n    66→                    asChild\n    67→                    defaultOpen={item.isActive}\n    68→                    className='group/collapsible'\n    69→                  >\n    70→                    <SidebarMenuItem>\n    71→                      <CollapsibleTrigger asChild>\n    72→                        <SidebarMenuButton tooltip={item.title} isActive={pathname === item.url}>\n    73→                          {item.icon && <Icon />}\n    74→                          <span>{item.title}</span>\n    75→                          <Icons.chevronRight className='ml-auto transition-transform duration-200 group-data-[state=open]/collapsible:rotate-90' />\n    76→                        </SidebarMenuButton>\n    77→                      </CollapsibleTrigger>\n    78→                      <CollapsibleContent>\n    79→                        <SidebarMenuSub>\n    80→                          {item.items?.map((subItem) => (\n    81→                            <SidebarMenuSubItem key={subItem.title}>\n    82→                              <SidebarMenuSubButton asChild isActive={pathname === subItem.url}>\n    83→                                <Link href={subItem.url}>\n    84→                                  <span>{subItem.title}</span>\n    85→                                </Link>\n    86→                              </SidebarMenuSubButton>\n    87→                            </SidebarMenuSubItem>\n    88→                          ))}\n    89→                        </SidebarMenuSub>\n    90→                      </CollapsibleContent>\n    91→                    </SidebarMenuItem>\n    92→                  </Collapsible>\n    93→                ) : (\n    94→                  <SidebarMenuItem key={item.title}>\n    95→                    <SidebarMenuButton\n    96→                      asChild\n    97→                      tooltip={item.title}\n    98→                      isActive={pathname === item.url}\n    99→                    >\n   100→                      <Link href={item.url}>\n   101→                        <Icon />\n   102→                        <span>{item.title}</span>\n   103→                      </Link>\n   104→                    </SidebarMenuButton>\n   105→                  </SidebarMenuItem>\n   106→                );\n   107→              })}\n   108→            </SidebarMenu>\n   109→          </SidebarGroup>\n   110→        ))}\n   111→      </SidebarContent>\n   112→      <SidebarFooter>\n   113→        <SidebarMenu>\n   114→          <SidebarMenuItem>\n   115→            <DropdownMenu>\n   116→              <DropdownMenuTrigger asChild>\n   117→                <SidebarMenuButton\n   118→                  size='lg'\n   119→                  className='data-[state=open]:bg-sidebar-accent data-[state=open]:text-sidebar-accent-foreground'\n   120→                >\n   121→                  {user && (\n   122→                    <UserAvatarProfile className='h-8 w-8 rounded-lg' showInfo user={user} />\n   123→                  )}\n   124→                  <Icons.chevronsDown className='ml-auto size-4' />\n   125→                </SidebarMenuButton>\n   126→              </DropdownMenuTrigger>\n   127→              <DropdownMenuContent\n   128→                className='w-(--radix-dropdown-menu-trigger-width) min-w-56 rounded-lg'\n   129→                side='bottom'\n   130→                align='end'\n   131→                sideOffset={4}\n   132→              >\n   133→                <DropdownMenuLabel className='p-0 font-normal'>\n   134→                  <div className='px-1 py-1.5'>\n   135→                    {user && (\n   136→                      <UserAvatarProfile className='h-8 w-8 rounded-lg' showInfo user={user} />\n   137→                    )}\n   138→                  </div>\n   139→                </DropdownMenuLabel>\n   140→                <DropdownMenuSeparator />\n   141→\n   142→                <DropdownMenuGroup>\n   143→                  <DropdownMenuItem onClick={() => router.push('/dashboard/profile')}>\n   144→                    <Icons.account className='mr-2 h-4 w-4' />\n   145→                    Profile\n   146→                  </DropdownMenuItem>\n   147→                  {organization && (\n   148→                    <DropdownMenuItem onClick={() => router.push('/dashboard/billing')}>\n   149→                      <Icons.creditCard className='mr-2 h-4 w-4' />\n   150→                      Billing\n   151→                    </DropdownMenuItem>\n   152→                  )}\n   153→                  <DropdownMenuItem onClick={() => router.push('/dashboard/notifications')}>\n   154→                    <Icons.notification className='mr-2 h-4 w-4' />\n   155→                    Notifications\n   156→                  </DropdownMenuItem>\n   157→                </DropdownMenuGroup>\n   158→                <DropdownMenuSeparator />\n   159→                <DropdownMenuItem>\n   160→                  <Icons.logout className='mr-2 h-4 w-4' />\n   161→                  <SignOutButton redirectUrl='/auth/sign-in' />\n   162→                </DropdownMenuItem>\n   163→              </DropdownMenuContent>\n   164→            </DropdownMenu>\n   165→          </SidebarMenuItem>\n   166→        </SidebarMenu>\n   167→      </SidebarFooter>\n   168→      <SidebarRail />\n   169→    </Sidebar>\n   170→  );\n   171→}\n   172→"}]},"parent_tool_use_id":"toolu_01DjkRt2s5AW41mL3CCnbyiT","session_id":"6ea8e296-285c-40ca-8f7e-7bee15998b6e","uuid":"5e4ad70b-4c87-43b7-bcca-cf5037fda151"}
