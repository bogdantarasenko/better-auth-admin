{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0153tCogWnaUJC2LNBxfhVBw","type":"tool_result","content":"     1→'use client';\n     2→\n     3→/**\n     4→ * Fully client-side hook for filtering navigation items based on RBAC\n     5→ *\n     6→ * This hook uses better-auth's client-side hooks to check roles and organization\n     7→ * without any server calls. This is perfect for navigation visibility (UX only).\n     8→ *\n     9→ * Note: For actual security (API routes, server actions), always use server-side checks.\n    10→ * This is only for UI visibility.\n    11→ */\n    12→\n    13→import { useMemo } from 'react';\n    14→import { authClient } from '@/lib/auth-client';\n    15→import type { NavItem, NavGroup } from '@/types';\n    16→\n    17→/**\n    18→ * Hook to filter navigation items based on RBAC (fully client-side)\n    19→ *\n    20→ * @param items - Array of navigation items to filter\n    21→ * @returns Filtered items\n    22→ */\n    23→export function useFilteredNavItems(items: NavItem[]) {\n    24→  const { data: activeOrg } = authClient.useActiveOrganization();\n    25→  const { data: session } = authClient.useSession();\n    26→  const { data: activeMember } = authClient.useActiveMember();\n    27→\n    28→  // Memoize context and permissions\n    29→  const accessContext = useMemo(() => {\n    30→    const role = activeMember?.role;\n    31→\n    32→    return {\n    33→      organization: activeOrg ?? undefined,\n    34→      user: session?.user ?? undefined,\n    35→      role: role ?? undefined,\n    36→      hasOrg: !!activeOrg\n    37→    };\n    38→  }, [activeOrg?.id, session?.user?.id, activeMember?.role]);\n    39→\n    40→  // Filter items synchronously (all client-side)\n    41→  const filteredItems = useMemo(() => {\n    42→    return items\n    43→      .filter((item) => checkAccess(item, accessContext))\n    44→      .map((item) => {\n    45→        // Recursively filter child items\n    46→        if (item.items && item.items.length > 0) {\n    47→          return {\n    48→            ...item,\n    49→            items: item.items.filter((childItem) =>\n    50→              checkAccess(childItem, accessContext)\n    51→            )\n    52→          };\n    53→        }\n    54→\n    55→        return item;\n    56→      });\n    57→  }, [items, accessContext]);\n    58→\n    59→  return filteredItems;\n    60→}\n    61→\n    62→interface AccessContext {\n    63→  organization: unknown;\n    64→  user: unknown;\n    65→  role: string | undefined;\n    66→  hasOrg: boolean;\n    67→}\n    68→\n    69→function checkAccess(item: NavItem, ctx: AccessContext): boolean {\n    70→  if (!item.access) {\n    71→    return true;\n    72→  }\n    73→\n    74→  // Check requireOrg\n    75→  if (item.access.requireOrg && !ctx.hasOrg) {\n    76→    return false;\n    77→  }\n    78→\n    79→  // Check permission (requires org context)\n    80→  if (item.access.permission) {\n    81→    if (!ctx.hasOrg) {\n    82→      return false;\n    83→    }\n    84→    // Permission checks use role-based access in better-auth\n    85→    // For now, owner and admin roles have all permissions\n    86→    if (ctx.role !== 'owner' && ctx.role !== 'admin') {\n    87→      return false;\n    88→    }\n    89→  }\n    90→\n    91→  // Check role\n    92→  if (item.access.role) {\n    93→    if (!ctx.hasOrg) {\n    94→      return false;\n    95→    }\n    96→    if (ctx.role !== item.access.role) {\n    97→      return false;\n    98→    }\n    99→  }\n   100→\n   101→  // Plan/feature checks require stripe plugin (US-008)\n   102→  // For now, show items and let page-level protection handle it\n   103→  if (item.access.plan || item.access.feature) {\n   104→    console.warn(\n   105→      `Plan/feature checks for navigation items require server-side verification. ` +\n   106→        `Item \"${item.title}\" will be shown, but page-level protection should be implemented.`\n   107→    );\n   108→  }\n   109→\n   110→  return true;\n   111→}\n   112→\n   113→/**\n   114→ * Hook to filter navigation groups based on RBAC (fully client-side)\n   115→ *\n   116→ * @param groups - Array of navigation groups to filter\n   117→ * @returns Filtered groups (empty groups are removed)\n   118→ */\n   119→export function useFilteredNavGroups(groups: NavGroup[]) {\n   120→  const allItems = useMemo(() => groups.flatMap((g) => g.items), [groups]);\n   121→  const filteredItems = useFilteredNavItems(allItems);\n   122→\n   123→  return useMemo(() => {\n   124→    const filteredSet = new Set(filteredItems.map((item) => item.title));\n   125→    return groups\n   126→      .map((group) => ({\n   127→        ...group,\n   128→        items: filteredItems.filter((item) =>\n   129→          group.items.some((gi) => gi.title === item.title && filteredSet.has(gi.title))\n   130→        )\n   131→      }))\n   132→      .filter((group) => group.items.length > 0);\n   133→  }, [groups, filteredItems]);\n   134→}\n   135→"}]},"parent_tool_use_id":null,"session_id":"5ecfe1e9-6f52-4d05-b142-586fa1064d01","uuid":"15e00689-eb5f-4644-8239-e563f8c6314f","tool_use_result":{"type":"text","file":{"filePath":"/Users/bogdantarasenko/Desktop/hackinterview-tool/next-shadcn-dashboard-starter/src/hooks/use-nav.ts","content":"'use client';\n\n/**\n * Fully client-side hook for filtering navigation items based on RBAC\n *\n * This hook uses better-auth's client-side hooks to check roles and organization\n * without any server calls. This is perfect for navigation visibility (UX only).\n *\n * Note: For actual security (API routes, server actions), always use server-side checks.\n * This is only for UI visibility.\n */\n\nimport { useMemo } from 'react';\nimport { authClient } from '@/lib/auth-client';\nimport type { NavItem, NavGroup } from '@/types';\n\n/**\n * Hook to filter navigation items based on RBAC (fully client-side)\n *\n * @param items - Array of navigation items to filter\n * @returns Filtered items\n */\nexport function useFilteredNavItems(items: NavItem[]) {\n  const { data: activeOrg } = authClient.useActiveOrganization();\n  const { data: session } = authClient.useSession();\n  const { data: activeMember } = authClient.useActiveMember();\n\n  // Memoize context and permissions\n  const accessContext = useMemo(() => {\n    const role = activeMember?.role;\n\n    return {\n      organization: activeOrg ?? undefined,\n      user: session?.user ?? undefined,\n      role: role ?? undefined,\n      hasOrg: !!activeOrg\n    };\n  }, [activeOrg?.id, session?.user?.id, activeMember?.role]);\n\n  // Filter items synchronously (all client-side)\n  const filteredItems = useMemo(() => {\n    return items\n      .filter((item) => checkAccess(item, accessContext))\n      .map((item) => {\n        // Recursively filter child items\n        if (item.items && item.items.length > 0) {\n          return {\n            ...item,\n            items: item.items.filter((childItem) =>\n              checkAccess(childItem, accessContext)\n            )\n          };\n        }\n\n        return item;\n      });\n  }, [items, accessContext]);\n\n  return filteredItems;\n}\n\ninterface AccessContext {\n  organization: unknown;\n  user: unknown;\n  role: string | undefined;\n  hasOrg: boolean;\n}\n\nfunction checkAccess(item: NavItem, ctx: AccessContext): boolean {\n  if (!item.access) {\n    return true;\n  }\n\n  // Check requireOrg\n  if (item.access.requireOrg && !ctx.hasOrg) {\n    return false;\n  }\n\n  // Check permission (requires org context)\n  if (item.access.permission) {\n    if (!ctx.hasOrg) {\n      return false;\n    }\n    // Permission checks use role-based access in better-auth\n    // For now, owner and admin roles have all permissions\n    if (ctx.role !== 'owner' && ctx.role !== 'admin') {\n      return false;\n    }\n  }\n\n  // Check role\n  if (item.access.role) {\n    if (!ctx.hasOrg) {\n      return false;\n    }\n    if (ctx.role !== item.access.role) {\n      return false;\n    }\n  }\n\n  // Plan/feature checks require stripe plugin (US-008)\n  // For now, show items and let page-level protection handle it\n  if (item.access.plan || item.access.feature) {\n    console.warn(\n      `Plan/feature checks for navigation items require server-side verification. ` +\n        `Item \"${item.title}\" will be shown, but page-level protection should be implemented.`\n    );\n  }\n\n  return true;\n}\n\n/**\n * Hook to filter navigation groups based on RBAC (fully client-side)\n *\n * @param groups - Array of navigation groups to filter\n * @returns Filtered groups (empty groups are removed)\n */\nexport function useFilteredNavGroups(groups: NavGroup[]) {\n  const allItems = useMemo(() => groups.flatMap((g) => g.items), [groups]);\n  const filteredItems = useFilteredNavItems(allItems);\n\n  return useMemo(() => {\n    const filteredSet = new Set(filteredItems.map((item) => item.title));\n    return groups\n      .map((group) => ({\n        ...group,\n        items: filteredItems.filter((item) =>\n          group.items.some((gi) => gi.title === item.title && filteredSet.has(gi.title))\n        )\n      }))\n      .filter((group) => group.items.length > 0);\n  }, [groups, filteredItems]);\n}\n","numLines":135,"startLine":1,"totalLines":135}}}
