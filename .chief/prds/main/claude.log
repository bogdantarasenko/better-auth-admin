{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ed5bPPJ9tKtcwn3z4cu2rJ","type":"tool_result","content":"     1→'use client';\n     2→\n     3→import { useAuth, useOrganizationList } from '@clerk/nextjs';\n     4→import { Icons } from '@/components/icons';\n     5→import Image from 'next/image';\n     6→import { useRouter } from 'next/navigation';\n     7→\n     8→import {\n     9→  DropdownMenu,\n    10→  DropdownMenuContent,\n    11→  DropdownMenuItem,\n    12→  DropdownMenuLabel,\n    13→  DropdownMenuSeparator,\n    14→  DropdownMenuShortcut,\n    15→  DropdownMenuTrigger\n    16→} from '@/components/ui/dropdown-menu';\n    17→import {\n    18→  SidebarMenu,\n    19→  SidebarMenuButton,\n    20→  SidebarMenuItem,\n    21→  useSidebar\n    22→} from '@/components/ui/sidebar';\n    23→import { useEffect } from 'react';\n    24→\n    25→export function OrgSwitcher() {\n    26→  const { isMobile, state } = useSidebar();\n    27→  const router = useRouter();\n    28→  const { isLoaded, setActive, userMemberships } = useOrganizationList({\n    29→    userMemberships: {\n    30→      infinite: true,\n    31→      keepPreviousData: false\n    32→    }\n    33→  });\n    34→\n    35→  const { orgId } = useAuth();\n    36→\n    37→  useEffect(() => {\n    38→    if (userMemberships?.revalidate) {\n    39→      void userMemberships.revalidate();\n    40→    }\n    41→    // eslint-disable-next-line react-hooks/exhaustive-deps -- only revalidate when org changes, not on every userMemberships ref change\n    42→  }, [orgId]);\n    43→\n    44→  // Get the currently active organization\n    45→  const activeOrganization = userMemberships?.data?.find(\n    46→    (membership) => membership.organization.id === orgId\n    47→  )?.organization;\n    48→\n    49→  // Handle organization switch\n    50→  const handleOrganizationSwitch = async (organizationId: string) => {\n    51→    if (orgId === organizationId || !setActive) {\n    52→      return; // Already active or setActive not available\n    53→    }\n    54→    try {\n    55→      await setActive({ organization: organizationId });\n    56→    } catch (error) {\n    57→      console.error('Failed to switch organization:', error);\n    58→    }\n    59→  };\n    60→\n    61→  // Show loading state\n    62→  if (!isLoaded) {\n    63→    return (\n    64→      <SidebarMenu>\n    65→        <SidebarMenuItem>\n    66→          <SidebarMenuButton size='lg' disabled>\n    67→            <div className='bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 shrink-0 items-center justify-center rounded-lg'>\n    68→              <Icons.galleryVerticalEnd className='size-4' />\n    69→            </div>\n    70→            <div\n    71→              className={`grid flex-1 text-left text-sm leading-tight transition-all duration-200 ease-in-out ${\n    72→                state === 'collapsed'\n    73→                  ? 'invisible max-w-0 overflow-hidden opacity-0'\n    74→                  : 'visible max-w-full opacity-100'\n    75→              }`}\n    76→            >\n    77→              <span className='truncate font-medium'>Loading...</span>\n    78→              <span className='text-muted-foreground truncate text-xs'>Organizations</span>\n    79→            </div>\n    80→          </SidebarMenuButton>\n    81→        </SidebarMenuItem>\n    82→      </SidebarMenu>\n    83→    );\n    84→  }\n    85→\n    86→  // Show create organization option if no organizations\n    87→  if (!userMemberships?.data || userMemberships.data.length === 0) {\n    88→    return (\n    89→      <SidebarMenu>\n    90→        <SidebarMenuItem>\n    91→          <SidebarMenuButton\n    92→            size='lg'\n    93→            onClick={() => router.push('/dashboard/workspaces')}\n    94→            className='data-[state=open]:bg-sidebar-accent data-[state=open]:text-sidebar-accent-foreground'\n    95→          >\n    96→            <div className='bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 shrink-0 items-center justify-center overflow-hidden rounded-lg'>\n    97→              <Icons.add className='size-4' />\n    98→            </div>\n    99→            <div\n   100→              className={`grid flex-1 text-left text-sm leading-tight transition-all duration-200 ease-in-out ${\n   101→                state === 'collapsed'\n   102→                  ? 'invisible max-w-0 overflow-hidden opacity-0'\n   103→                  : 'visible max-w-full opacity-100'\n   104→              }`}\n   105→            >\n   106→              <span className='truncate font-medium'>Create organization</span>\n   107→              <span className='text-muted-foreground truncate text-xs'>Get started</span>\n   108→            </div>\n   109→            <Icons.chevronsUpDown\n   110→              className={`ml-auto transition-all duration-200 ease-in-out ${\n   111→                state === 'collapsed'\n   112→                  ? 'invisible max-w-0 opacity-0'\n   113→                  : 'visible max-w-full opacity-100'\n   114→              }`}\n   115→            />\n   116→          </SidebarMenuButton>\n   117→        </SidebarMenuItem>\n   118→      </SidebarMenu>\n   119→    );\n   120→  }\n   121→\n   122→  // Use active organization or first organization as fallback\n   123→  const displayOrganization = activeOrganization || userMemberships.data[0]?.organization;\n   124→\n   125→  if (!displayOrganization) {\n   126→    return null;\n   127→  }\n   128→\n   129→  return (\n   130→    <SidebarMenu>\n   131→      <SidebarMenuItem>\n   132→        <DropdownMenu>\n   133→          <DropdownMenuTrigger asChild>\n   134→            <SidebarMenuButton\n   135→              size='lg'\n   136→              className='data-[state=open]:bg-sidebar-accent data-[state=open]:text-sidebar-accent-foreground'\n   137→            >\n   138→              <div className='bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 shrink-0 items-center justify-center overflow-hidden rounded-lg'>\n   139→                {displayOrganization.hasImage && displayOrganization.imageUrl ? (\n   140→                  <Image\n   141→                    src={displayOrganization.imageUrl}\n   142→                    alt={displayOrganization.name}\n   143→                    width={32}\n   144→                    height={32}\n   145→                    className='size-full object-cover'\n   146→                  />\n   147→                ) : (\n   148→                  <Icons.galleryVerticalEnd className='size-4' />\n   149→                )}\n   150→              </div>\n   151→              <div\n   152→                className={`grid flex-1 text-left text-sm leading-tight transition-all duration-200 ease-in-out ${\n   153→                  state === 'collapsed'\n   154→                    ? 'invisible max-w-0 overflow-hidden opacity-0'\n   155→                    : 'visible max-w-full opacity-100'\n   156→                }`}\n   157→              >\n   158→                <span className='truncate font-medium'>{displayOrganization.name}</span>\n   159→                <span className='text-muted-foreground truncate text-xs'>\n   160→                  {userMemberships.data.find((m) => m.organization.id === displayOrganization.id)\n   161→                    ?.role || 'Organization'}\n   162→                </span>\n   163→              </div>\n   164→              <Icons.chevronsUpDown\n   165→                className={`ml-auto transition-all duration-200 ease-in-out ${\n   166→                  state === 'collapsed'\n   167→                    ? 'invisible max-w-0 opacity-0'\n   168→                    : 'visible max-w-full opacity-100'\n   169→                }`}\n   170→              />\n   171→            </SidebarMenuButton>\n   172→          </DropdownMenuTrigger>\n   173→          <DropdownMenuContent\n   174→            className='w-[--radix-dropdown-menu-trigger-width] min-w-56 rounded-lg'\n   175→            align='start'\n   176→            side={isMobile ? 'bottom' : 'right'}\n   177→            sideOffset={4}\n   178→          >\n   179→            <DropdownMenuLabel className='text-muted-foreground text-xs'>\n   180→              Organizations\n   181→            </DropdownMenuLabel>\n   182→            {userMemberships.data.map((membership, index) => {\n   183→              const isActive = membership.organization.id === orgId;\n   184→              return (\n   185→                <DropdownMenuItem\n   186→                  key={membership.id}\n   187→                  onClick={() => handleOrganizationSwitch(membership.organization.id)}\n   188→                  className='gap-2 p-2'\n   189→                >\n   190→                  <div className='flex size-6 items-center justify-center overflow-hidden rounded-md border'>\n   191→                    {membership.organization.hasImage && membership.organization.imageUrl ? (\n   192→                      <Image\n   193→                        src={membership.organization.imageUrl}\n   194→                        alt={membership.organization.name}\n   195→                        width={24}\n   196→                        height={24}\n   197→                        className='size-full object-cover'\n   198→                      />\n   199→                    ) : (\n   200→                      <Icons.galleryVerticalEnd className='size-3.5 shrink-0' />\n   201→                    )}\n   202→                  </div>\n   203→                  {membership.organization.name}\n   204→                  {isActive && <Icons.check className='ml-auto size-4' />}\n   205→                  {!isActive && <DropdownMenuShortcut>⌘{index + 1}</DropdownMenuShortcut>}\n   206→                </DropdownMenuItem>\n   207→              );\n   208→            })}\n   209→            <DropdownMenuSeparator />\n   210→            <DropdownMenuItem\n   211→              className='gap-2 p-2'\n   212→              onClick={() => {\n   213→                router.push('/dashboard/workspaces');\n   214→              }}\n   215→            >\n   216→              <div className='flex size-6 items-center justify-center rounded-md border bg-transparent'>\n   217→                <Icons.add className='size-4' />\n   218→              </div>\n   219→              <div className='text-muted-foreground font-medium'>Add organization</div>\n   220→            </DropdownMenuItem>\n   221→          </DropdownMenuContent>\n   222→        </DropdownMenu>\n   223→      </SidebarMenuItem>\n   224→    </SidebarMenu>\n   225→  );\n   226→}\n   227→"}]},"parent_tool_use_id":"toolu_01DjkRt2s5AW41mL3CCnbyiT","session_id":"6ea8e296-285c-40ca-8f7e-7bee15998b6e","uuid":"b44ff748-95b7-45e7-b1b7-0e8e3ca41652"}
