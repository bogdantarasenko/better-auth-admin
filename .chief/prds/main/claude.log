{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016hwb4LFKJ37JTpTm4617tY","type":"tool_result","content":"     1→'use client';\n     2→\n     3→/**\n     4→ * Fully client-side hook for filtering navigation items based on RBAC\n     5→ *\n     6→ * This hook uses Clerk's client-side hooks to check permissions, roles, and organization\n     7→ * without any server calls. This is perfect for navigation visibility (UX only).\n     8→ *\n     9→ * Performance:\n    10→ * - All checks are synchronous (no server calls)\n    11→ * - Instant filtering\n    12→ * - No loading states\n    13→ * - No UI flashing\n    14→ *\n    15→ * Note: For actual security (API routes, server actions), always use server-side checks.\n    16→ * This is only for UI visibility.\n    17→ */\n    18→\n    19→import { useMemo } from 'react';\n    20→import { useOrganization, useUser } from '@clerk/nextjs';\n    21→import type { NavItem, NavGroup } from '@/types';\n    22→\n    23→/**\n    24→ * Hook to filter navigation items based on RBAC (fully client-side)\n    25→ *\n    26→ * @param items - Array of navigation items to filter\n    27→ * @returns Filtered items\n    28→ */\n    29→export function useFilteredNavItems(items: NavItem[]) {\n    30→  const { organization, membership } = useOrganization();\n    31→  const { user } = useUser();\n    32→\n    33→  // Memoize context and permissions\n    34→  const accessContext = useMemo(() => {\n    35→    const permissions = membership?.permissions || [];\n    36→    const role = membership?.role;\n    37→\n    38→    return {\n    39→      organization: organization ?? undefined,\n    40→      user: user ?? undefined,\n    41→      permissions: permissions as string[],\n    42→      role: role ?? undefined,\n    43→      hasOrg: !!organization\n    44→    };\n    45→    // eslint-disable-next-line react-hooks/exhaustive-deps -- using stable primitives to avoid infinite re-renders from unstable Clerk object refs\n    46→  }, [organization?.id, user?.id, membership?.permissions, membership?.role]);\n    47→\n    48→  // Filter items synchronously (all client-side)\n    49→  const filteredItems = useMemo(() => {\n    50→    return items\n    51→      .filter((item) => {\n    52→        // No access restrictions\n    53→        if (!item.access) {\n    54→          return true;\n    55→        }\n    56→\n    57→        // Check requireOrg\n    58→        if (item.access.requireOrg && !accessContext.hasOrg) {\n    59→          return false;\n    60→        }\n    61→\n    62→        // Check permission\n    63→        if (item.access.permission) {\n    64→          if (!accessContext.hasOrg) {\n    65→            return false;\n    66→          }\n    67→          if (!accessContext.permissions.includes(item.access.permission)) {\n    68→            return false;\n    69→          }\n    70→        }\n    71→\n    72→        // Check role\n    73→        if (item.access.role) {\n    74→          if (!accessContext.hasOrg) {\n    75→            return false;\n    76→          }\n    77→          if (accessContext.role !== item.access.role) {\n    78→            return false;\n    79→          }\n    80→        }\n    81→\n    82→        // Note: Plans and features require server-side checks with Clerk's has() function\n    83→        // For navigation visibility, you can either:\n    84→        // 1. Store plan/feature info in organization metadata (client-accessible)\n    85→        // 2. Use server actions (current approach)\n    86→        // 3. Skip plan/feature checks for navigation (recommended for performance)\n    87→\n    88→        // For now, if plan/feature is specified, we'll need to handle it differently\n    89→        // Most navigation items won't need plan/feature checks anyway\n    90→        if (item.access.plan || item.access.feature) {\n    91→          // Option: Return true and let the page handle it, or use server action\n    92→          // For now, we'll show it (page-level protection should handle it)\n    93→          console.warn(\n    94→            `Plan/feature checks for navigation items require server-side verification. ` +\n    95→              `Item \"${item.title}\" will be shown, but page-level protection should be implemented.`\n    96→          );\n    97→        }\n    98→\n    99→        return true;\n   100→      })\n   101→      .map((item) => {\n   102→        // Recursively filter child items\n   103→        if (item.items && item.items.length > 0) {\n   104→          const filteredChildren = item.items.filter((childItem) => {\n   105→            // No access restrictions\n   106→            if (!childItem.access) {\n   107→              return true;\n   108→            }\n   109→\n   110→            // Check requireOrg\n   111→            if (childItem.access.requireOrg && !accessContext.hasOrg) {\n   112→              return false;\n   113→            }\n   114→\n   115→            // Check permission\n   116→            if (childItem.access.permission) {\n   117→              if (!accessContext.hasOrg) {\n   118→                return false;\n   119→              }\n   120→              if (!accessContext.permissions.includes(childItem.access.permission)) {\n   121→                return false;\n   122→              }\n   123→            }\n   124→\n   125→            // Check role\n   126→            if (childItem.access.role) {\n   127→              if (!accessContext.hasOrg) {\n   128→                return false;\n   129→              }\n   130→              if (accessContext.role !== childItem.access.role) {\n   131→                return false;\n   132→              }\n   133→            }\n   134→\n   135→            // Plan/feature checks (same warning as above)\n   136→            if (childItem.access.plan || childItem.access.feature) {\n   137→              console.warn(\n   138→                `Plan/feature checks for navigation items require server-side verification. ` +\n   139→                  `Item \"${childItem.title}\" will be shown, but page-level protection should be implemented.`\n   140→              );\n   141→            }\n   142→\n   143→            return true;\n   144→          });\n   145→\n   146→          return {\n   147→            ...item,\n   148→            items: filteredChildren\n   149→          };\n   150→        }\n   151→\n   152→        return item;\n   153→      });\n   154→  }, [items, accessContext]);\n   155→\n   156→  return filteredItems;\n   157→}\n   158→\n   159→/**\n   160→ * Hook to filter navigation groups based on RBAC (fully client-side)\n   161→ *\n   162→ * @param groups - Array of navigation groups to filter\n   163→ * @returns Filtered groups (empty groups are removed)\n   164→ */\n   165→export function useFilteredNavGroups(groups: NavGroup[]) {\n   166→  const allItems = useMemo(() => groups.flatMap((g) => g.items), [groups]);\n   167→  const filteredItems = useFilteredNavItems(allItems);\n   168→\n   169→  return useMemo(() => {\n   170→    const filteredSet = new Set(filteredItems.map((item) => item.title));\n   171→    return groups\n   172→      .map((group) => ({\n   173→        ...group,\n   174→        items: filteredItems.filter((item) =>\n   175→          group.items.some((gi) => gi.title === item.title && filteredSet.has(gi.title))\n   176→        )\n   177→      }))\n   178→      .filter((group) => group.items.length > 0);\n   179→  }, [groups, filteredItems]);\n   180→}\n   181→"}]},"parent_tool_use_id":null,"session_id":"5446c01b-aad1-4950-90be-ff6f7dc92b2d","uuid":"5f58bd1a-e5c0-4935-9be0-c5e19484662e","tool_use_result":{"type":"text","file":{"filePath":"/Users/bogdantarasenko/Desktop/hackinterview-tool/next-shadcn-dashboard-starter/src/hooks/use-nav.ts","content":"'use client';\n\n/**\n * Fully client-side hook for filtering navigation items based on RBAC\n *\n * This hook uses Clerk's client-side hooks to check permissions, roles, and organization\n * without any server calls. This is perfect for navigation visibility (UX only).\n *\n * Performance:\n * - All checks are synchronous (no server calls)\n * - Instant filtering\n * - No loading states\n * - No UI flashing\n *\n * Note: For actual security (API routes, server actions), always use server-side checks.\n * This is only for UI visibility.\n */\n\nimport { useMemo } from 'react';\nimport { useOrganization, useUser } from '@clerk/nextjs';\nimport type { NavItem, NavGroup } from '@/types';\n\n/**\n * Hook to filter navigation items based on RBAC (fully client-side)\n *\n * @param items - Array of navigation items to filter\n * @returns Filtered items\n */\nexport function useFilteredNavItems(items: NavItem[]) {\n  const { organization, membership } = useOrganization();\n  const { user } = useUser();\n\n  // Memoize context and permissions\n  const accessContext = useMemo(() => {\n    const permissions = membership?.permissions || [];\n    const role = membership?.role;\n\n    return {\n      organization: organization ?? undefined,\n      user: user ?? undefined,\n      permissions: permissions as string[],\n      role: role ?? undefined,\n      hasOrg: !!organization\n    };\n    // eslint-disable-next-line react-hooks/exhaustive-deps -- using stable primitives to avoid infinite re-renders from unstable Clerk object refs\n  }, [organization?.id, user?.id, membership?.permissions, membership?.role]);\n\n  // Filter items synchronously (all client-side)\n  const filteredItems = useMemo(() => {\n    return items\n      .filter((item) => {\n        // No access restrictions\n        if (!item.access) {\n          return true;\n        }\n\n        // Check requireOrg\n        if (item.access.requireOrg && !accessContext.hasOrg) {\n          return false;\n        }\n\n        // Check permission\n        if (item.access.permission) {\n          if (!accessContext.hasOrg) {\n            return false;\n          }\n          if (!accessContext.permissions.includes(item.access.permission)) {\n            return false;\n          }\n        }\n\n        // Check role\n        if (item.access.role) {\n          if (!accessContext.hasOrg) {\n            return false;\n          }\n          if (accessContext.role !== item.access.role) {\n            return false;\n          }\n        }\n\n        // Note: Plans and features require server-side checks with Clerk's has() function\n        // For navigation visibility, you can either:\n        // 1. Store plan/feature info in organization metadata (client-accessible)\n        // 2. Use server actions (current approach)\n        // 3. Skip plan/feature checks for navigation (recommended for performance)\n\n        // For now, if plan/feature is specified, we'll need to handle it differently\n        // Most navigation items won't need plan/feature checks anyway\n        if (item.access.plan || item.access.feature) {\n          // Option: Return true and let the page handle it, or use server action\n          // For now, we'll show it (page-level protection should handle it)\n          console.warn(\n            `Plan/feature checks for navigation items require server-side verification. ` +\n              `Item \"${item.title}\" will be shown, but page-level protection should be implemented.`\n          );\n        }\n\n        return true;\n      })\n      .map((item) => {\n        // Recursively filter child items\n        if (item.items && item.items.length > 0) {\n          const filteredChildren = item.items.filter((childItem) => {\n            // No access restrictions\n            if (!childItem.access) {\n              return true;\n            }\n\n            // Check requireOrg\n            if (childItem.access.requireOrg && !accessContext.hasOrg) {\n              return false;\n            }\n\n            // Check permission\n            if (childItem.access.permission) {\n              if (!accessContext.hasOrg) {\n                return false;\n              }\n              if (!accessContext.permissions.includes(childItem.access.permission)) {\n                return false;\n              }\n            }\n\n            // Check role\n            if (childItem.access.role) {\n              if (!accessContext.hasOrg) {\n                return false;\n              }\n              if (accessContext.role !== childItem.access.role) {\n                return false;\n              }\n            }\n\n            // Plan/feature checks (same warning as above)\n            if (childItem.access.plan || childItem.access.feature) {\n              console.warn(\n                `Plan/feature checks for navigation items require server-side verification. ` +\n                  `Item \"${childItem.title}\" will be shown, but page-level protection should be implemented.`\n              );\n            }\n\n            return true;\n          });\n\n          return {\n            ...item,\n            items: filteredChildren\n          };\n        }\n\n        return item;\n      });\n  }, [items, accessContext]);\n\n  return filteredItems;\n}\n\n/**\n * Hook to filter navigation groups based on RBAC (fully client-side)\n *\n * @param groups - Array of navigation groups to filter\n * @returns Filtered groups (empty groups are removed)\n */\nexport function useFilteredNavGroups(groups: NavGroup[]) {\n  const allItems = useMemo(() => groups.flatMap((g) => g.items), [groups]);\n  const filteredItems = useFilteredNavItems(allItems);\n\n  return useMemo(() => {\n    const filteredSet = new Set(filteredItems.map((item) => item.title));\n    return groups\n      .map((group) => ({\n        ...group,\n        items: filteredItems.filter((item) =>\n          group.items.some((gi) => gi.title === item.title && filteredSet.has(gi.title))\n        )\n      }))\n      .filter((group) => group.items.length > 0);\n  }, [groups, filteredItems]);\n}\n","numLines":181,"startLine":1,"totalLines":181}}}
