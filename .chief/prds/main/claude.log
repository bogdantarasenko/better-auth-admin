{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015E4QuEmENgcFX2C9GJY1xR","type":"tool_result","content":"     1→import { clerkMiddleware, createRouteMatcher } from '@clerk/nextjs/server';\n     2→import { NextRequest } from 'next/server';\n     3→\n     4→const isProtectedRoute = createRouteMatcher(['/dashboard(.*)']);\n     5→\n     6→export default clerkMiddleware(async (auth, req: NextRequest) => {\n     7→  if (isProtectedRoute(req)) await auth.protect();\n     8→});\n     9→export const config = {\n    10→  matcher: [\n    11→    // Skip Next.js internals and all static files, unless found in search params\n    12→    '/((?!_next|[^?]*\\\\.(?:html?|css|js(?!on)|jpe?g|webp|png|gif|svg|ttf|woff2?|ico|csv|docx?|xlsx?|zip|webmanifest)).*)',\n    13→    // Always run for API routes\n    14→    '/(api|trpc)(.*)'\n    15→  ]\n    16→};\n    17→"}]},"parent_tool_use_id":null,"session_id":"ce8911dc-a828-4e89-bfb5-264eebf8fb2a","uuid":"1eb66baa-243d-469c-a925-77c57b13df61","tool_use_result":{"type":"text","file":{"filePath":"/Users/bogdantarasenko/Desktop/hackinterview-tool/next-shadcn-dashboard-starter/src/proxy.ts","content":"import { clerkMiddleware, createRouteMatcher } from '@clerk/nextjs/server';\nimport { NextRequest } from 'next/server';\n\nconst isProtectedRoute = createRouteMatcher(['/dashboard(.*)']);\n\nexport default clerkMiddleware(async (auth, req: NextRequest) => {\n  if (isProtectedRoute(req)) await auth.protect();\n});\nexport const config = {\n  matcher: [\n    // Skip Next.js internals and all static files, unless found in search params\n    '/((?!_next|[^?]*\\\\.(?:html?|css|js(?!on)|jpe?g|webp|png|gif|svg|ttf|woff2?|ico|csv|docx?|xlsx?|zip|webmanifest)).*)',\n    // Always run for API routes\n    '/(api|trpc)(.*)'\n  ]\n};\n","numLines":17,"startLine":1,"totalLines":17}}}
