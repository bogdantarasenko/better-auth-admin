{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018FfEi8zttAuTBjVnvGk5fX","type":"tool_result","content":"     1→'use client';\n     2→import { AuthUIProvider } from '@daveyplate/better-auth-ui';\n     3→import Link from 'next/link';\n     4→import { useRouter } from 'next/navigation';\n     5→import React from 'react';\n     6→import { authClient } from '@/lib/auth-client';\n     7→import { ActiveThemeProvider } from '../themes/active-theme';\n     8→import QueryProvider from './query-provider';\n     9→\n    10→export default function Providers({\n    11→  activeThemeValue,\n    12→  children\n    13→}: {\n    14→  activeThemeValue: string;\n    15→  children: React.ReactNode;\n    16→}) {\n    17→  const router = useRouter();\n    18→\n    19→  return (\n    20→    <>\n    21→      <ActiveThemeProvider initialTheme={activeThemeValue}>\n    22→        <AuthUIProvider\n    23→          authClient={authClient}\n    24→          navigate={router.push}\n    25→          replace={router.replace}\n    26→          onSessionChange={() => {\n    27→            router.refresh();\n    28→          }}\n    29→          redirectTo='/dashboard/overview'\n    30→          Link={Link}\n    31→        >\n    32→          <QueryProvider>{children}</QueryProvider>\n    33→        </AuthUIProvider>\n    34→      </ActiveThemeProvider>\n    35→    </>\n    36→  );\n    37→}\n    38→"}]},"parent_tool_use_id":"toolu_0162RUw3p8h4hfwnhBUqGwTM","session_id":"5831c654-5660-41f9-8789-6e410bfc3f8c","uuid":"eb702c26-764b-4c5d-b65e-b03ffdc8e107"}
