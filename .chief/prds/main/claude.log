not set */\n    clip-path: circle(0% at var(--x, 50%) var(--y, 50%));\n    opacity: 0.7;\n  }\n  to {\n    /* Use CSS variables for the origin, defaulting to center if not set */\n    clip-path: circle(150% at var(--x, 50%) var(--y, 50%));\n    opacity: 1;\n  }\n}\n\n::view-transition-new(root) {\n  /* Apply the reveal animation */\n  animation: reveal 0.4s ease-in-out forwards;\n}\n","structuredPatch":[{"oldStart":2,"oldLines":6,"newStart":2,"newLines":8,"lines":[" "," @import 'tw-animate-css';"," ","+@import '@daveyplate/better-auth-ui/css';","+"," @custom-variant dark (&:is(.dark *));"," "," @import './theme.css';"]}],"userModified":false,"replaceAll":false}}
