{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QaEc8wHjdPdn3T29URgkHZ","type":"tool_result","content":"     1→import Providers from '@/components/layout/providers';\n     2→import { Toaster } from '@/components/ui/sonner';\n     3→import { fontVariables } from '@/components/themes/font.config';\n     4→import { DEFAULT_THEME, THEMES } from '@/components/themes/theme.config';\n     5→import ThemeProvider from '@/components/themes/theme-provider';\n     6→import { cn } from '@/lib/utils';\n     7→import type { Metadata, Viewport } from 'next';\n     8→import { cookies } from 'next/headers';\n     9→import NextTopLoader from 'nextjs-toploader';\n    10→import { NuqsAdapter } from 'nuqs/adapters/next/app';\n    11→import '../styles/globals.css';\n    12→\n    13→const META_THEME_COLORS = {\n    14→  light: '#ffffff',\n    15→  dark: '#09090b'\n    16→};\n    17→\n    18→export const metadata: Metadata = {\n    19→  title: 'Next Shadcn',\n    20→  description: 'Basic dashboard with Next.js and Shadcn'\n    21→};\n    22→\n    23→export const viewport: Viewport = {\n    24→  themeColor: META_THEME_COLORS.light\n    25→};\n    26→\n    27→export default async function RootLayout({ children }: { children: React.ReactNode }) {\n    28→  const cookieStore = await cookies();\n    29→  const activeThemeValue = cookieStore.get('active_theme')?.value;\n    30→  const isValidTheme = THEMES.some((t) => t.value === activeThemeValue);\n    31→  const themeToApply = isValidTheme ? activeThemeValue! : DEFAULT_THEME;\n    32→\n    33→  return (\n    34→    <html lang='en' suppressHydrationWarning data-theme={themeToApply}>\n    35→      <head>\n    36→        <script\n    37→          dangerouslySetInnerHTML={{\n    38→            __html: `\n    39→              try {\n    40→                // Set meta theme color\n    41→                if (localStorage.theme === 'dark' || ((!('theme' in localStorage) || localStorage.theme === 'system') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {\n    42→                  document.querySelector('meta[name=\"theme-color\"]')?.setAttribute('content', '${META_THEME_COLORS.dark}')\n    43→                }\n    44→              } catch (_) {}\n    45→            `\n    46→          }}\n    47→        />\n    48→      </head>\n    49→      <body\n    50→        className={cn(\n    51→          'bg-background overflow-x-hidden overscroll-none font-sans antialiased',\n    52→          fontVariables\n    53→        )}\n    54→      >\n    55→        <NextTopLoader color='var(--primary)' showSpinner={false} />\n    56→        <NuqsAdapter>\n    57→          <ThemeProvider\n    58→            attribute='class'\n    59→            defaultTheme='system'\n    60→            enableSystem\n    61→            disableTransitionOnChange\n    62→            enableColorScheme\n    63→          >\n    64→            <Providers activeThemeValue={themeToApply}>\n    65→              <Toaster />\n    66→              {children}\n    67→            </Providers>\n    68→          </ThemeProvider>\n    69→        </NuqsAdapter>\n    70→      </body>\n    71→    </html>\n    72→  );\n    73→}\n    74→"}]},"parent_tool_use_id":"toolu_0162RUw3p8h4hfwnhBUqGwTM","session_id":"5831c654-5660-41f9-8789-6e410bfc3f8c","uuid":"220d52b0-4b34-485a-8a63-4432f6d699c2"}
